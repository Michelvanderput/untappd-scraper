# ===========================================
# BeerMenu / Untappd Scraper – Environment
# ===========================================
# Kopieer naar .env en vul de waarden in.
# .env wordt niet gecommit (staat in .gitignore).

# ---- Frontend (Vite) ----
# Ollama Cloud API key voor de AI-chatbot (BeerBot).
# Zonder key werkt de chatbot niet; rest van de app wel.
VITE_OLLAMA_API_KEY=

# Optioneel: model voor Ollama Cloud (default: ministral-3:3b)
# VITE_OLLAMA_CLOUD_MODEL=ministral-3:3b

# ---- API (Vercel serverless) ----
# Dezelfde key moet in Vercel Environment Variables staan als VITE_OLLAMA_API_KEY
# (de proxy leest process.env.VITE_OLLAMA_API_KEY)

# ---- Scraper (lokaal / GitHub Actions) ----
# Optioneel: contact voor User-Agent (bijv. jouw@email.nl)
# SCRAPER_CONTACT_EMAIL=
